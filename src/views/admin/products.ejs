<%- include('partials/header') %>

<% if (action === 'list') { %>

    <div style="display:flex; justify-content:space-between; margin-bottom: 20px;">
        <h3 class="section-title" style="margin:0; border:none;">Manage Products</h3>
        <a href="/admin/products?action=add" class="btn btn-primary"><i class="fas fa-plus"></i> Add New Product</a>
    </div>

    <% if (success) { %>
        <div style="background:#e8f8f5; color:#2ecc71; padding:15px; border-radius:4px; margin-bottom:20px; border:1px solid #a3e4d7;">
            <i class="fas fa-check-circle"></i> <%= success %>
        </div>
    <% } %>

    <div class="card">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Featured</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(p) { %>
                    <tr>
                        <td>
                            <% if (p.image_url) { %>
                                <img src="<%= p.image_url.startsWith('http') ? p.image_url : '/' + p.image_url %>" alt="Product" width="50" height="50" style="object-fit:cover; border-radius:4px;">
                            <% } else { %>
                                <div style="width:50px; height:50px; background:#eee; border-radius:4px; display:flex; align-items:center; justify-content:center; color:#999;"><i class="fas fa-image"></i></div>
                            <% } %>
                        </td>
                        <td style="font-weight: 500; color: var(--maroon);"><%= p.name %></td>
                        <td><%= p.category_name %></td>
                        <td>
                            Rs. <%= money(p.price) %>
                            <% if (p.sale_price) { %>
                                <br><small style="color:var(--gold);">Sale: Rs. <%= money(p.sale_price) %></small>
                            <% } %>
                        </td>
                        <td>
                            <% if (p.stock < 5) { %>
                                <span style="color:#e74c3c; font-weight:bold;"><%= p.stock %> (Low)</span>
                            <% } else { %>
                                <%= p.stock %>
                            <% } %>
                        </td>
                        <td><%= p.featured ? '<span class="badge badge-delivered">Yes</span>' : '-' %></td>
                        <td>
                            <a href="/admin/products?action=edit&id=<%= p.id %>" class="btn btn-sm btn-gold" title="Edit"><i class="fas fa-edit"></i></a>
                            <form method="POST" action="/admin/products/delete" onsubmit="return confirm('Are you sure you want to delete this product?');" style="display:inline;">
                                <input type="hidden" name="id" value="<%= p.id %>">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

<% } else if (action === 'add' || action === 'edit') { %>

    <div class="card">
        <h3 class="section-title"><%= action === 'add' ? 'Add New Product' : 'Edit Product' %></h3>

        <% if (error) { %>
            <div style="background:#fff0f0; color:#e74c3c; padding:15px; border-radius:4px; margin-bottom:20px; border:1px solid #ffcccc;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/admin/products/<%= action %>" enctype="multipart/form-data">
            <input type="hidden" name="product_id" value="<%= p ? p.id : '' %>">
            <input type="hidden" name="current_image" value="<%= p ? (p.image_url || '') : '' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                <div>
                    <label class="form-label">Product Name *</label>
                    <input type="text" name="name" class="form-control" required value="<%= p ? p.name : '' %>">
                </div>
                <div>
                    <label class="form-label">Category *</label>
                    <select name="category_id" class="form-control" required>
                        <option value="">Select Category</option>
                        <% categories.forEach(function(c) { %>
                            <option value="<%= c.id %>" <%= (p && p.category_id == c.id) ? 'selected' : '' %>><%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="form-label">Regular Price (Rs) *</label>
                    <input type="number" name="price" class="form-control" required value="<%= p ? p.price : '' %>">
                </div>
                <div>
                    <label class="form-label">Sale Price (Rs) (Optional)</label>
                    <input type="number" name="sale_price" class="form-control" value="<%= p ? (p.sale_price || '') : '' %>">
                </div>
                <div>
                    <label class="form-label">Stock Quantity *</label>
                    <input type="number" name="stock" class="form-control" required value="<%= p ? p.stock : '10' %>">
                </div>
                <div>
                    <label class="form-label">Product Image</label>
                    <input type="file" name="image" class="form-control" accept="image/*">
                    <% if (p && p.image_url) { %>
                        <small style="color:#777;">Current: <img src="<%= p.image_url.startsWith('http') ? p.image_url : '/' + p.image_url %>" height="30" style="vertical-align:middle;"></small>
                    <% } %>
                </div>
                <div>
                    <label class="form-label">Sizes (Comma separated)</label>
                    <input type="text" name="sizes" class="form-control" placeholder="XS, S, M, L, XL" value="<%= p ? (p.sizes || '') : '' %>">
                </div>
                <div>
                    <label class="form-label">Colors (Comma separated)</label>
                    <input type="text" name="colors" class="form-control" placeholder="Maroon, Gold, Black" value="<%= p ? (p.colors || '') : '' %>">
                </div>
            </div>

            <div style="margin-top: 15px;">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="5" required><%= p ? p.description : '' %></textarea>
            </div>

            <div style="margin-top: 15px; display:flex; align-items:center; gap:10px;">
                <input type="checkbox" name="featured" id="featured" <%= (p && p.featured) ? 'checked' : '' %> style="width:20px;height:20px;accent-color:var(--maroon);">
                <label for="featured" style="font-weight:500; cursor:pointer; color:#444;">Mark as Featured Product (Shows on Homepage)</label>
            </div>

            <div style="margin-top: 30px; border-top:1px solid #eee; padding-top:20px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Product</button>
                <a href="/admin/products" class="btn" style="background:#eee; color:#333; margin-left:10px;">Cancel</a>
            </div>
        </form>
    </div>

<% } %>

<%- include('partials/footer') %>
